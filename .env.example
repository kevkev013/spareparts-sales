# Database (Neon PostgreSQL via Vercel)
# Pooled connection (for serverless/Vercel runtime)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.neon.tech/neondb?sslmode=require"
# Direct connection (for migrations)
DATABASE_URL_UNPOOLED="postgresql://user:password@ep-xxx.region.neon.tech/neondb?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# Admin seed password (required in production, min 8 chars, mixed case + number)
ADMIN_INITIAL_PASSWORD="Admin123"

# App
NODE_ENV="development"

# Google Sheets Backup (via Apps Script)
# Lihat panduan setup: docs/google-apps-script-backup.js
GOOGLE_SCRIPT_URL="https://script.google.com/macros/s/xxx/exec"
BACKUP_SECRET="ganti-dengan-password-rahasia-kamu"

# Vercel Cron Secret (generate with: openssl rand -base64 32)
CRON_SECRET="your-cron-secret-here"
